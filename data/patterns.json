  "structure": {
    "broetry": {
      "label": "Broetry format",
      "maxPoints": 8,
      "thresholds": {
        "high": { "ratio": 0.6, "points": 8 },
        "medium": { "ratio": 0.4, "points": 4 }
      }
    },
    "hookStoreLessonCTA": {
      "label": "Hook-Story-Lesson-CTA arc",
      "maxPoints": 10,
      "hook": {
        "points": 2,
        "description": "First sentence is question, exclamation, or strong claim"
      },
      "story": {
        "points": 2,
        "markers": ["I was", "I remember", "Last week", "Last month", "Last year", "Years ago", "A few years ago", "When I was", "One day", "Recently"]
      },
      "lesson": {
        "points": 3,
        "markers": ["here's what I learned", "here is what I learned", "the lesson", "key takeaway", "what this taught me", "the biggest lesson", "what I realized", "my takeaway"]
      },
      "cta": {
        "points": 3,
        "markers": ["agree?", "thoughts?", "what do you think?", "share if", "repost if", "tag someone", "let me know", "drop a comment", "comment below"]
      }
    },
    "numberedWisdom": {
      "label": "Numbered wisdom lists",
      "maxPoints": 7
    },
    "formulaicEndings": {
      "label": "Formulaic endings",
      "maxPoints": 5,
      "patterns": [
        { "regex": "\\b(agree|thoughts)\\?\\s*$", "points": 3 },
        { "regex": "what do you think\\?\\s*$", "points": 3 },
        { "regex": "(repost|share) if (this resonated|you agree)", "points": 5 },
        { "regex": "tag someone who needs this", "points": 5 },
        { "regex": "follow me for more", "points": 4 },
        { "regex": "follow for daily", "points": 4 }
      ]
    },
    "negativeParallelisms": {
      "label": "Negative parallelisms",
      "maxPoints": 4,
      "pointsEach": 2,
      "patterns": ["not just", "not only", "it's not about.*it's about", "it is not about.*it is about"]
    },
    "ruleOfThree": {
      "label": "Rule of three",
      "maxPoints": 4
    },
    "falseRanges": {
      "label": "False ranges",
      "maxPoints": 3,
      "regex": "from .+ to .+, from .+ to"
    }
  },
  "stylometry": {
    "sentenceLengthVariance": {
      "label": "Sentence length variance",
      "maxPoints": 8,
      "minSentences": 4,
      "thresholds": {
        "low": { "cv": 0.3, "points": 8 },
        "medium": { "cv": 0.5, "points": 4 }
      }
    },
    "emDashDensity": {
      "label": "Em dash density",
      "maxPoints": 4,
      "thresholds": {
        "high": { "per100Words": 4, "points": 4 },
        "medium": { "per100Words": 2, "points": 2 }
      }
    },
    "paragraphUniformity": {
      "label": "Paragraph length uniformity",
      "maxPoints": 4,
      "minParagraphs": 3,
      "thresholds": {
        "low": { "cv": 0.3, "points": 4 },
        "medium": { "cv": 0.5, "points": 2 }
      }
    },
    "hedgingDensity": {
      "label": "Hedging density",
      "maxPoints": 4,
      "phrases": ["perhaps", "it could be argued", "potentially", "it might be said", "arguably", "it is possible", "one could argue", "it may be", "it seems", "it appears"],
      "thresholds": {
        "high": { "per100Words": 3, "points": 4 },
        "medium": { "per100Words": 2, "points": 2 }
      }
    },
    "perfectGrammar": {
      "label": "Perfect grammar signal",
      "maxPoints": 3,
      "minWords": 100,
      "contractions": ["don't", "can't", "won't", "I'm", "I've", "I'll", "I'd", "we're", "we've", "they're", "they've", "isn't", "aren't", "wasn't", "weren't", "hasn't", "haven't", "hadn't", "doesn't", "didn't", "couldn't", "wouldn't", "shouldn't", "it's", "that's", "there's", "here's", "what's", "who's", "let's"]
    },
    "superficialIng": {
      "label": "Superficial -ing phrases",
      "maxPoints": 2,
      "words": ["highlighting", "underscoring", "emphasizing", "reflecting", "showcasing", "ensuring", "symbolizing", "contributing to", "cultivating", "fostering", "encompassing"]
    }
  },
  "linkedin": {
    "hashtagStuffing": {
      "label": "Hashtag stuffing",
      "maxPoints": 3,
      "thresholds": {
        "high": { "count": 5, "points": 3 },
        "medium": { "count": 3, "points": 1 }
      }
    },
    "emojiAsStructure": {
      "label": "Emoji as structure",
      "maxPoints": 4,
      "thresholds": {
        "high": { "count": 3, "points": 4 },
        "medium": { "count": 1, "points": 2 }
      }
    },
    "personalBrandFormula": {
      "label": "Personal brand formula",
      "maxPoints": 5,
      "openingTriggers": ["I was rejected", "I was fired", "I was told no", "I failed", "I got rejected", "I lost my job", "I was laid off", "I dropped out"],
      "reversalMarkers": ["but then", "fast forward", "today I", "now I", "that's when", "everything changed"],
      "lessonMarkers": ["here's what I learned", "here is what I learned", "the lesson", "what this taught me"]
    },
    "scrollManipulation": {
      "label": "Scroll manipulation",
      "maxPoints": 3,
      "ratioThreshold": 0.5
    }
  },
