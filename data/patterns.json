    "8": {
      "name": "Copula avoidance",
      "phrases": ["serves as", "stands as", "marks a", "represents a", "boasts a", "features a", "offers a"]
    },
    "9": {
      "name": "Negative parallelisms",
      "patterns": ["not only.*but", "it's not just about.*it's", "it is not just about.*it is"]
    },
    "10": {
      "name": "Rule of three",
      "description": "Forcing ideas into groups of exactly three"
    },
    "11": {
      "name": "Synonym cycling",
      "description": "Referring to the same entity by multiple different names to avoid repetition"
    },
    "12": {
      "name": "False ranges",
      "patterns": ["from .+ to .+, from .+ to"]
    },
    "13": {
      "name": "Em dash overuse",
      "description": "Using em dashes far more frequently than human writing norms"
    },
    "14": {
      "name": "Boldface overuse",
      "description": "Mechanically emphasizing phrases in bold"
    },
    "15": {
      "name": "Inline-header vertical lists",
      "description": "Bullet points starting with bold header followed by explanation"
    },
    "16": {
      "name": "Title case in headings",
      "description": "Capitalizing all main words in every heading"
    },
    "17": {
      "name": "Emoji decoration",
      "description": "Using emojis as bullet points or section markers"
    },
    "18": {
      "name": "Curly quotation marks",
      "description": "ChatGPT uses curly quotes vs straight quotes"
    },
    "19": {
      "name": "Communication artifacts",
      "phrases": ["I hope this helps", "Of course!", "Certainly!", "You're absolutely right!", "Would you like", "Let me know", "Here is a"]
    },
    "20": {
      "name": "Knowledge-cutoff disclaimers",
      "phrases": ["as of my last", "up to my last training update", "while specific details are limited", "while specific details are scarce", "based on available information"]
    },
    "21": {
      "name": "Sycophantic tone",
      "phrases": ["Great question!", "You're absolutely right!", "That's an excellent point"]
    },
    "22": {
      "name": "Filler phrases",
      "phrases": ["in order to", "due to the fact that", "at this point in time", "it is important to note that", "it is worth mentioning that"]
    },
    "23": {
      "name": "Excessive hedging",
      "phrases": ["could potentially", "it might be argued", "one could argue", "it is possible that", "it could be said"]
    },
    "24": {
      "name": "Generic positive conclusions",
      "phrases": ["the future looks bright", "exciting times lie ahead", "this represents a major step", "a step in the right direction", "paving the way for", "the possibilities are endless"]
