    "7": {
      "name": "AI vocabulary (high-frequency)",
      "words": ["additionally", "align with", "crucial", "delve", "emphasizing", "enduring", "enhance", "fostering", "garner", "highlight", "interplay", "intricate", "intricacies", "key", "landscape", "pivotal", "showcase", "tapestry", "testament", "underscore", "valuable", "vibrant"]
